{"id":"foundation-014","title":"比较与过去时间单元","new_words":[{"id":"w-was","text":"was","ipa":"/wʌz; wəz/","meaning":"是；在（am/is 的过去式）","phrase":"was here","example":"I was here."},{"id":"w-more","text":"more","ipa":"/mɔːr/","meaning":"更多；更大程度","phrase":"more than one","example":"This is more than one."},{"id":"w-than","text":"than","ipa":"/ðæn; ðən/","meaning":"比；用于比较","phrase":"more than one","example":"Two is more than one."},{"id":"w-ago","text":"ago","ipa":"/əˈɡoʊ/","meaning":"以前；之前","phrase":"one day ago","example":"I was here one day ago."},{"id":"w-recently","text":"recently","ipa":"/ˈriːsntli/","meaning":"最近","phrase":"was here recently","example":"I was here recently."},{"id":"w-previously","text":"previously","ipa":"/ˈpriːviəsli/","meaning":"以前；先前","phrase":"was here previously","example":"I was here previously."}],"sentences":[{"text":"I was here.","meaning":"我过去在这里。"},{"text":"This is more than one.","meaning":"这比一个更多。"},{"text":"Two is more than one.","meaning":"二比一大。"},{"text":"I was here one day ago.","meaning":"我一天前在这里。"},{"text":"I was here recently.","meaning":"我最近在这里。"},{"text":"I was here previously.","meaning":"我先前在这里。"}],"reading":{"title":"配套阅读","sentences":["I was here.","I was there.","This is more than one.","Two is more than one.","More is more than one.","This is more than one.","I was here one day ago.","You were not here one day ago.","I was here recently.","I was there recently.","I was here previously.","I was there previously."],"questions":[]}}